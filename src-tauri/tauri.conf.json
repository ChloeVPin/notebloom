{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "NoteBloom",
  "version": "1.2.0",
  "identifier": "com.chloe.notebloom",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "NoteBloom",
        "width": 1100,
        "height": 720,
        "minWidth": 1100,
        "minHeight": 720,
        "center": true,
        "decorations": false,
        "transparent": false,
        "shadow": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/logo.png",
      "icons/icon.ico"
    ]
  }
}
